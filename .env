VITE_GOOGLE_CLIENT_ID=76784847542-tjniogne89hemk955f503r48vrueh9dl.apps.googleusercontent.com
VITE_API_BASE_URL=https://senior-project-backend-patg.onrender.com

# Provider options: erapi | host | frankfurter
VITE_FX_PROVIDER=host

# Always keep THB as base for your app
VITE_FX_BASE=THB

# Optional. If set, fetch historical rates for that day (YYYY-MM-DD).
# Example: lock to a 2025 rate snapshot:
VITE_FX_DATE=2025-07-01

# Optional JSON for manual overrides (merged after fetch)
# Example forces 1 THB ≈ 0.0289 USD and 130 MMK
VITE_FX_OVERRIDE={"USD":0.0289,"MMK":130}
